# Database connection string for production
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/unisphere?retryWrites=true&w=majority

# Optional frontend API URL when using separate deployment
# In a monorepo Vercel deployment this is not required, as /api routes are served from the same domain.
VITE_API_URL=https://your-vercel-app.vercel.app/api
